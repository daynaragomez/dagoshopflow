@page "{id:int}"
@model DagoShopFlow.Web.Pages.Products.DetailModel
@{
    ViewData["Title"] = Model.Product?.Name ?? "Product";
}

@if (Model.Product is null)
{
    <div class="alert alert-danger">Product not found.</div>
}
else
{
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/Index">Products</a></li>
            <li class="breadcrumb-item"><a asp-page="/Index" asp-route-category="@Model.Product.Category">@Model.Product.Category</a></li>
            <li class="breadcrumb-item active">@Model.Product.Name</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-md-5">
            <img src="@Model.Product.ImageUrl" alt="@Model.Product.Name" class="img-fluid rounded shadow" />
        </div>
        <div class="col-md-7">
            <span class="badge bg-secondary mb-2">@Model.Product.Category</span>
            <h1 class="h2">@Model.Product.Name</h1>
            <p class="fs-4 fw-bold text-success my-3">$@Model.Product.Price.ToString("0.00")</p>
            <p class="text-muted">@Model.Product.Description</p>
            <p class="text-muted small">In stock: @Model.Product.Stock units</p>

            <form method="post" asp-page-handler="AddToCart" class="mt-4">
                <input type="hidden" name="productId" value="@Model.Product.Id" />
                <div class="d-flex align-items-center gap-3">
                    <div style="width:100px">
                        <label class="form-label">Quantity</label>
                        <input type="number" name="qty" value="1" min="1" max="@Model.Product.Stock"
                               class="form-control" data-testid="detail-qty-input" />
                    </div>
                    <div class="mt-3">
                        <button type="submit" class="btn btn-primary btn-lg" data-testid="add-to-cart-@Model.Product.Id">
                            <i class="bi bi-cart-plus"></i> Add to Cart
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
}
